.admin-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
}

/* ===== 态势总览 ===== */
.overview-card {
  padding: 32rpx 28rpx 24rpx;
  border-radius: 32rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(255, 251, 249, 0.96));
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.08);
}

.overview-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.overview-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #1f2937;
}

.overview-sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #7b7b86;
}

.overview-tag {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(208, 2, 27, 0.08);
  color: #d0021b;
  font-size: 22rpx;
  font-weight: 800;
  flex-shrink: 0;
}

.overview-grid {
  margin-top: 28rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.overview-item {
  flex: 1 1 calc(33.333% - 16rpx);
  min-width: 180rpx;
  padding: 22rpx 20rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fff 0%, #fcf7f5 100%);
  border: 2rpx solid rgba(208, 2, 27, 0.08);
}

.overview-label {
  font-size: 22rpx;
  color: #8e8e95;
}

.overview-value {
  margin-top: 12rpx;
  font-size: 44rpx;
  font-weight: 800;
  color: #1f2937;
  line-height: 1;
}

.overview-value.warn { color: #ff7a00; }
.overview-value.danger { color: #d0021b; }
.overview-value.good { color: #07c160; }

/* ===== Tab 栏 ===== */
.tab-bar {
  margin-top: 24rpx;
  display: flex;
  background: rgba(255, 255, 255, 0.88);
  border-radius: 28rpx;
  padding: 8rpx;
  border: 2rpx solid rgba(208, 2, 27, 0.08);
}

.tab-btn {
  flex: 1;
  text-align: center;
  padding: 22rpx 12rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #7b7b86;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.tab-btn.active {
  color: #ffffff;
  background: linear-gradient(135deg, #9f0014, #d0021b);
  box-shadow: 0 10rpx 24rpx rgba(208, 2, 27, 0.22);
}

.tab-count {
  background: #ffffff;
  color: #d0021b;
  font-size: 20rpx;
  font-weight: 800;
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  min-width: 32rpx;
  text-align: center;
}

.tab-btn.active .tab-count {
  background: rgba(255, 255, 255, 0.92);
}

.tab-panel {
  margin-top: 24rpx;
}

/* ===== 记录列表 ===== */
.filter-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.filter-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #374151;
}

.refresh-btn {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  border: 2rpx solid #ebe6e4;
  background: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  color: #555;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.record-card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 28rpx;
  padding: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.68);
  box-shadow: 0 14rpx 30rpx rgba(15, 23, 42, 0.08);
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
}

.record-thumbs {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex-shrink: 0;
}

.record-thumb {
  width: 140rpx;
  height: 140rpx;
  border-radius: 18rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.65);
  box-shadow: 0 10rpx 18rpx rgba(15, 23, 42, 0.10);
}

.thumb-more {
  width: 140rpx;
  height: 60rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #fff8f6 0%, #f7f2f0 100%);
  border: 2rpx solid #ebe6e4;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #8e8e95;
  font-weight: 700;
}

.record-body {
  flex: 1;
  min-width: 0;
}

.record-top {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 12rpx;
}

.section-badge {
  background: linear-gradient(180deg, #fff4f2 0%, #ffeceb 100%);
  border: 2rpx solid rgba(208, 2, 27, 0.16);
  color: #d0021b;
  font-size: 22rpx;
  font-weight: 800;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  letter-spacing: 2rpx;
}

.record-id {
  font-size: 22rpx;
  color: #b7b7bf;
}

.record-photo-count {
  margin-left: auto;
  font-size: 22rpx;
  color: #9ca3af;
}

.record-desc {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.6;
  margin-bottom: 14rpx;
}

.record-desc.empty {
  color: #b3b3bb;
  font-style: italic;
}

.record-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
}

.meta-item {
  font-size: 22rpx;
  color: #8e8e95;
}

.status-pill {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
  border: 2rpx solid transparent;
}

.status-pill.pending { color: #ff7a00; border-color: #ffd9b0; background: #fff8f0; }
.status-pill.progress { color: #1677ff; border-color: #b0d4ff; background: #f0f7ff; }
.status-pill.done { color: #07c160; border-color: #b0e8c7; background: #f0fdf4; }

/* ===== 空态 ===== */
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 28rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.68);
  box-shadow: 0 14rpx 30rpx rgba(15, 23, 42, 0.06);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #374151;
  margin-bottom: 10rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #9ca3af;
}

/* ===== 统计 Tab ===== */
.stats-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.stat-card {
  flex: 1 1 calc(50% - 20rpx);
  min-width: 260rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(255, 250, 248, 0.96));
  border-radius: 28rpx;
  padding: 28rpx 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.7);
  box-shadow: 0 14rpx 30rpx rgba(15, 23, 42, 0.08);
}

.stat-label {
  font-size: 24rpx;
  color: #8e8e95;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  margin-top: 12rpx;
  font-size: 60rpx;
  font-weight: 800;
  line-height: 1;
}

.stat-value.red { color: #d0021b; }
.stat-value.orange { color: #ff7a00; }
.stat-value.green { color: #07c160; }

.stat-sub {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #b4b4bc;
}

.stats-section-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #374151;
  margin-bottom: 18rpx;
  padding-left: 8rpx;
}

.section-stat-row {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 22rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.68);
  box-shadow: 0 14rpx 30rpx rgba(15, 23, 42, 0.06);
}

.section-stat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.section-stat-name {
  font-size: 26rpx;
  font-weight: 700;
}

.section-stat-count {
  font-size: 30rpx;
  font-weight: 800;
}

.progress-bar {
  height: 14rpx;
  background: #f0f0f0;
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  transition: width 0.4s ease;
}

/* ===== 详情弹层 ===== */
.detail-overlay {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.56);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 900;
}

.detail-card {
  width: 100%;
  max-height: 90vh;
  overflow-y: auto;
  background: linear-gradient(180deg, #fff 0%, #fffaf8 100%);
  border-radius: 32rpx 32rpx 0 0;
  padding: 36rpx 28rpx 40rpx;
  box-shadow: 0 -20rpx 60rpx rgba(15, 23, 42, 0.18);
}

.detail-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.detail-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #1f2937;
}

.detail-sub {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8e8e95;
}

.detail-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(15, 23, 42, 0.06);
  color: #4b5563;
  font-size: 36rpx;
  line-height: 56rpx;
  text-align: center;
  flex-shrink: 0;
}

.detail-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.detail-item {
  flex: 1 1 calc(50% - 16rpx);
  min-width: 240rpx;
  padding: 20rpx 22rpx;
  border-radius: 22rpx;
  background: #ffffff;
  border: 2rpx solid rgba(208, 2, 27, 0.08);
}

.detail-label {
  font-size: 22rpx;
  color: #8e8e95;
}

.detail-value {
  margin-top: 10rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #1f2937;
  line-height: 1.5;
  word-break: break-all;
}

.detail-section {
  margin-top: 12rpx;
  margin-bottom: 24rpx;
}

.detail-section-title {
  font-size: 26rpx;
  font-weight: 800;
  color: #374151;
  margin-bottom: 14rpx;
}

.detail-desc {
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: #ffffff;
  border: 2rpx solid rgba(208, 2, 27, 0.08);
  font-size: 26rpx;
  line-height: 1.7;
  color: #374151;
}

.detail-desc.empty {
  color: #b3b3bb;
  font-style: italic;
}

.detail-images {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.detail-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 20rpx;
  box-shadow: 0 10rpx 20rpx rgba(15, 23, 42, 0.10);
}

.detail-actions {
  margin-top: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  flex-wrap: wrap;
}

.detail-status-wrap {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex-wrap: wrap;
}

.status-select {
  padding: 12rpx 26rpx;
  border-radius: 999rpx;
  border: 2rpx solid #e7e4e2;
  font-size: 24rpx;
  font-weight: 700;
  background: #ffffff;
  color: #1f2937;
}

.status-select.status-pending { color: #ff7a00; border-color: #ffd9b0; background: #fff8f0; }
.status-select.status-progress { color: #1677ff; border-color: #b0d4ff; background: #f0f7ff; }
.status-select.status-done { color: #07c160; border-color: #b0e8c7; background: #f0fdf4; }

.detail-save {
  padding: 22rpx 36rpx;
  border: none;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #9f0014, #d0021b);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 800;
  box-shadow: 0 14rpx 24rpx rgba(208, 2, 27, 0.22);
}

.detail-save[disabled] {
  background: #d7d7da;
  box-shadow: none;
  color: #8e8e95;
}
