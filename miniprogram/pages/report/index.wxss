.report-page {
  min-height: 100vh;
  padding-bottom: 168rpx;
}

.report-shell {
  padding-bottom: 36rpx;
}

.user-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 26rpx 24rpx;
}

.user-avatar {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #d0021b 0%, #ff7a00 100%);
  color: #ffffff;
  font-size: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 14rpx 26rpx rgba(208, 2, 27, 0.16);
  flex-shrink: 0;
}

.image-avatar {
  overflow: hidden;
}

.user-meta {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
}

.user-subline {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #9ca3af;
}

.section-pill {
  margin-left: 10rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(208, 2, 27, 0.1);
  color: #d0021b;
  font-weight: 700;
}

.switch-link {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #fff3f0;
  color: #9f0014;
  font-size: 22rpx;
  font-weight: 700;
}

.form-card {
  margin-top: 20rpx;
  padding: 28rpx 24rpx;
}

.block-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.head-left {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.head-dot {
  width: 8rpx;
  height: 32rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #d0021b 0%, #ff7a00 100%);
}

.head-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
}

.required-tag,
.optional-tag {
  padding: 4rpx 10rpx;
  border-radius: 10rpx;
  font-size: 18rpx;
  font-weight: 700;
}

.required-tag {
  background: linear-gradient(135deg, #d0021b 0%, #ef4444 100%);
  color: #ffffff;
}

.optional-tag {
  background: #f4f4f5;
  color: #71717a;
}

.head-count {
  font-size: 22rpx;
  color: #b6b6bd;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 22rpx;
}

.image-item {
  position: relative;
  width: 192rpx;
  height: 192rpx;
  border-radius: 22rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.12);
}

.image-thumb {
  width: 100%;
  height: 100%;
}

.image-del {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(15, 23, 42, 0.72);
  color: #ffffff;
  font-size: 26rpx;
  line-height: 40rpx;
  text-align: center;
}

.upload-box {
  margin-top: 22rpx;
  height: 250rpx;
  border: 3rpx dashed rgba(208, 2, 27, 0.36);
  border-radius: 28rpx;
  background: linear-gradient(180deg, #fffaf8 0%, #fff4f1 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  font-size: 60rpx;
}

.upload-title {
  margin-top: 12rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #d0021b;
}

.upload-subtitle {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #9ca3af;
}

.desc-textarea {
  width: 100%;
  height: 190rpx;
  margin-top: 22rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  border: 2rpx solid #ede6e3;
  background: linear-gradient(180deg, #fff 0%, #fbf8f7 100%);
  font-size: 28rpx;
  line-height: 1.6;
  color: #333333;
  box-sizing: border-box;
}

.desc-count {
  margin-top: 10rpx;
  text-align: right;
  font-size: 22rpx;
  color: #b6b6bd;
}

.desc-count-warn {
  color: #ff7a00;
}

.tips-box {
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  border: 2rpx solid #f9df8d;
  background: linear-gradient(180deg, #fffbed 0%, #fff6d9 100%);
  display: flex;
  gap: 12rpx;
}

.tips-icon {
  font-size: 30rpx;
  line-height: 1.5;
}

.tips-text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.7;
  color: #8a4b00;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 24rpx 32rpx;
  background: rgba(255, 255, 255, 0.92);
  border-top: 2rpx solid rgba(208, 2, 27, 0.08);
  box-sizing: border-box;
  backdrop-filter: blur(12rpx);
}

.submit-btn {
  height: 96rpx;
  border-radius: 28rpx;
  border: none;
  background: linear-gradient(135deg, #9f0014 0%, #d0021b 48%, #ff5a36 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 30rpx rgba(208, 2, 27, 0.26);
}

.submit-btn[disabled] {
  background: linear-gradient(180deg, #e8e8ea 0%, #d7d7da 100%);
  color: #8e8e95;
  box-shadow: none;
}

.success-mask {
  position: fixed;
  inset: 0;
  background: rgba(17, 24, 39, 0.56);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  box-sizing: border-box;
}

.success-card {
  width: 100%;
  padding: 44rpx 36rpx 36rpx;
  border-radius: 32rpx;
  background: linear-gradient(180deg, #fff 0%, #fffaf8 100%);
  text-align: center;
}

.success-icon {
  width: 116rpx;
  height: 116rpx;
  margin: 0 auto 24rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #07c160 0%, #04a14d 100%);
  color: #ffffff;
  font-size: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 24rpx rgba(7, 193, 96, 0.24);
}

.success-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #1f2937;
}

.success-copy {
  margin-top: 14rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #6b7280;
}

.success-note {
  margin-top: 22rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #f0fdf4;
  border: 2rpx solid #bbf7d0;
  font-size: 24rpx;
  line-height: 1.6;
  color: #166534;
}

.success-btn-primary {
  margin-top: 28rpx;
  height: 88rpx;
  border-radius: 24rpx;
  border: none;
  background: linear-gradient(135deg, #9f0014 0%, #d0021b 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 22rpx rgba(208, 2, 27, 0.24);
}

.success-btn-secondary {
  margin-top: 16rpx;
  height: 80rpx;
  border-radius: 24rpx;
  border: none;
  background: #f3f4f6;
  color: #6b7280;
  font-size: 26rpx;
  font-weight: 600;
}
