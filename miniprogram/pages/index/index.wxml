<view class="home-page">
  <scroll-view
    class="home-scroll"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    style="height: {{scrollHeight}}px;"
  >
    <view class="auth-screen">
      <view class="auth-status-pill">{{statusText}}</view>

      <view class="auth-logo">🛡️</view>

      <view class="auth-app-name">隐患随手拍</view>

      <block wx:if="{{isLoggedIn}}">
        <view class="auth-tagline auth-tagline-welcome">{{welcomeText}}</view>
      </block>
      <block wx:else>
        <view class="auth-tagline">10 秒上报 · 全员守护</view>
        <view class="auth-tagline-sub">让每个工友都成为安全守护者</view>
      </block>

      <view class="auth-features">
        <view class="auth-feature-item" wx:for="{{features}}" wx:key="text">
          <text class="auth-feature-icon">{{item.icon}}</text>
          <text class="auth-feature-text">{{item.text}}</text>
        </view>
      </view>

      <button class="btn-auth" bindtap="handleReportTap">{{primaryButtonText}}</button>

      <view class="my-reports-link" bindtap="handleMyReportsTap">
        <text class="my-reports-link-icon">📋</text>
        <text class="my-reports-link-text">查看我的举报记录</text>
        <text class="my-reports-link-arrow">›</text>
      </view>

      <view class="auth-hint">提交举报时需授权登录；数据将同步至后台便于处理</view>
      <view class="page-footer">中泰安哨·隐患智查平台</view>
    </view>
  </scroll-view>
</view>
