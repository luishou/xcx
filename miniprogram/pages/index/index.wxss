/* 首页：可滚动 + 安全区，主操作「点击上报」 */

page {
  height: 100%;
  box-sizing: border-box;
}

.home-page {
  height: 100%;
  background:
    radial-gradient(circle at top right, rgba(208, 2, 27, 0.06), transparent 28%),
    linear-gradient(180deg, #fffdfc 0%, #fff 38%, #fff8f7 100%);
  box-sizing: border-box;
}

.home-scroll {
  box-sizing: border-box;
}

.auth-screen {
  max-width: 750rpx;
  margin: 0 auto;
  padding: 32rpx 32rpx 0;
  padding-bottom: calc(32rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
  min-height: min-content;
}

.auth-status-pill {
  align-self: flex-end;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #9ca3af;
  background: rgba(243, 244, 246, 0.9);
  border: 2rpx solid rgba(208, 2, 27, 0.08);
  margin-bottom: 8rpx;
}

.auth-logo {
  width: 160rpx;
  height: 160rpx;
  margin-top: 16rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #d0021b 0%, #ef4444 56%, #ff7a00 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 76rpx;
  line-height: 1;
  box-shadow: 0 20rpx 40rpx rgba(208, 2, 27, 0.22);
  flex-shrink: 0;
}

.auth-app-name {
  margin-top: 36rpx;
  font-size: 44rpx;
  font-weight: 800;
  color: #1f2937;
  letter-spacing: 1rpx;
  text-align: center;
}

.auth-tagline {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #6b7280;
  text-align: center;
  line-height: 1.6;
  padding: 0 8rpx;
}

.auth-tagline-sub {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #9ca3af;
  text-align: center;
  line-height: 1.65;
  padding: 0 8rpx;
}

.auth-tagline-welcome {
  margin-top: 20rpx;
  padding: 0 8rpx;
  font-size: 26rpx;
  color: #4b5563;
  line-height: 1.75;
  text-align: center;
}

.auth-features {
  width: 100%;
  margin-top: 40rpx;
  padding: 28rpx 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(255, 249, 247, 0.95), rgba(255, 255, 255, 0.98));
  border: 2rpx solid rgba(255, 123, 95, 0.14);
  box-shadow: 0 18rpx 45rpx rgba(103, 22, 28, 0.08);
  box-sizing: border-box;
}

.auth-feature-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 16rpx 0;
}

.auth-feature-item + .auth-feature-item {
  border-top: 2rpx solid rgba(208, 2, 27, 0.08);
}

.auth-feature-icon {
  font-size: 36rpx;
  line-height: 1.3;
  flex-shrink: 0;
  width: 44rpx;
  text-align: center;
}

.auth-feature-text {
  flex: 1;
  font-size: 28rpx;
  color: #4b5563;
  line-height: 1.55;
  word-break: break-word;
}

.btn-auth {
  margin-top: 40rpx;
  width: 100%;
  min-height: 100rpx;
  line-height: 1.4;
  padding: 24rpx 20rpx;
  border-radius: 28rpx;
  border: none;
  background: linear-gradient(135deg, #17c964, #07a44f);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 16rpx 32rpx rgba(7, 193, 96, 0.26);
  box-sizing: border-box;
}

.btn-auth[disabled] {
  opacity: 0.75;
}

.my-reports-link {
  margin-top: 24rpx;
  width: 100%;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 2rpx solid #ebe6e4;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.04);
  box-sizing: border-box;
}

.my-reports-link-icon {
  font-size: 32rpx;
}

.my-reports-link-text {
  flex: 1;
  font-size: 28rpx;
  color: #374151;
  font-weight: 600;
}

.my-reports-link-arrow {
  font-size: 36rpx;
  color: #d1d5db;
  line-height: 1;
}

.auth-hint {
  margin-top: 28rpx;
  font-size: 22rpx;
  color: #9ca3af;
  text-align: center;
  line-height: 1.65;
  padding: 0 8rpx;
}

.page-footer {
  margin-top: 36rpx;
  margin-bottom: 8rpx;
  font-size: 22rpx;
  color: #d1d5db;
  text-align: center;
  letter-spacing: 0.5rpx;
  padding: 0 16rpx;
}

/* ===== 昵称头像授权弹窗 ===== */

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(17, 24, 39, 0.56);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.modal-box {
  width: 100%;
  max-width: 620rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fffaf8 100%);
  border-radius: 32rpx;
  padding: 44rpx 40rpx 36rpx;
  box-shadow: 0 26rpx 70rpx rgba(17, 24, 39, 0.18);
  box-sizing: border-box;
}

.modal-hd {
  text-align: center;
  margin-bottom: 36rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #1f2937;
  display: block;
  margin-bottom: 10rpx;
}

.modal-sub {
  font-size: 24rpx;
  color: #6b7280;
  display: block;
}

.modal-body {
  margin-bottom: 36rpx;
}

.modal-field {
  margin-bottom: 28rpx;
}

.modal-field:last-child {
  margin-bottom: 0;
}

.field-label {
  font-size: 26rpx;
  font-weight: 700;
  color: #374151;
  margin-bottom: 14rpx;
}

.avatar-pick-btn {
  background: transparent;
  padding: 0;
  margin: 0;
  border: none;
  width: 100%;
  display: flex;
  justify-content: center;
}

.avatar-pick-btn::after {
  border: none;
}

.avatar-preview {
  width: 140rpx;
  height: 140rpx;
  border-radius: 70rpx;
  border: 3rpx solid rgba(208, 2, 27, 0.15);
}

.avatar-placeholder {
  width: 140rpx;
  height: 140rpx;
  border-radius: 70rpx;
  background: #f9fafb;
  border: 2rpx dashed #e5e7eb;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.avatar-placeholder-icon {
  font-size: 48rpx;
  line-height: 1;
}

.avatar-placeholder-tip {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #9ca3af;
}

.nickname-input {
  width: 100%;
  height: 84rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1f2937;
  box-sizing: border-box;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  height: 84rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 700;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-btn::after {
  border: none;
}

.modal-btn-cancel {
  background: #f3f4f6;
  color: #6b7280;
}

.modal-btn-confirm {
  background: linear-gradient(135deg, #9f0014, #d0021b);
  color: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(208, 2, 27, 0.22);
}
