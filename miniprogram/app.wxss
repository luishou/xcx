page {
  min-height: 100%;
  background: linear-gradient(180deg, #fffaf8 0%, #f7f4f3 55%, #f4f7fb 100%);
  color: #1f2937;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page-shell {
  min-height: 100vh;
  padding: 28rpx 24rpx 40rpx;
}

.glass-card {
  background: rgba(255, 255, 255, 0.92);
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 32rpx;
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.08);
}

.primary-btn {
  height: 96rpx;
  border-radius: 28rpx;
  border: none;
  background: linear-gradient(135deg, #9f0014 0%, #d0021b 48%, #ff5a36 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.primary-btn[disabled] {
  background: linear-gradient(180deg, #e8e8ea 0%, #d7d7da 100%);
  color: #8e8e95;
}
