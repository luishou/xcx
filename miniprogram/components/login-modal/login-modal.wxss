.login-modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(17, 24, 39, 0.56);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.login-modal-box {
  width: 100%;
  max-width: 620rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fffaf8 100%);
  border-radius: 32rpx;
  padding: 44rpx 40rpx 36rpx;
  box-shadow: 0 26rpx 70rpx rgba(17, 24, 39, 0.18);
  box-sizing: border-box;
}

.login-modal-hd {
  text-align: center;
  margin-bottom: 36rpx;
}

.login-modal-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #1f2937;
  display: block;
  margin-bottom: 10rpx;
}

.login-modal-sub {
  font-size: 24rpx;
  color: #6b7280;
  display: block;
}

.login-modal-body {
  margin-bottom: 36rpx;
}

.login-modal-field {
  margin-bottom: 28rpx;
}

.login-modal-field:last-child {
  margin-bottom: 0;
}

.login-field-label {
  font-size: 26rpx;
  font-weight: 700;
  color: #374151;
  margin-bottom: 14rpx;
}

.login-avatar-pick-btn {
  background: transparent;
  padding: 0;
  margin: 0;
  border: none;
  width: 100%;
  display: flex;
  justify-content: center;
}

.login-avatar-pick-btn::after {
  border: none;
}

.login-avatar-preview {
  width: 140rpx;
  height: 140rpx;
  border-radius: 70rpx;
  border: 3rpx solid rgba(208, 2, 27, 0.15);
}

.login-avatar-placeholder {
  width: 140rpx;
  height: 140rpx;
  border-radius: 70rpx;
  background: #f9fafb;
  border: 2rpx dashed #e5e7eb;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.login-avatar-placeholder-icon {
  font-size: 48rpx;
  line-height: 1;
}

.login-avatar-placeholder-tip {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #9ca3af;
}

.login-nickname-input {
  width: 100%;
  height: 84rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1f2937;
  box-sizing: border-box;
}

.login-modal-footer {
  display: flex;
  gap: 20rpx;
}

.login-modal-btn {
  flex: 1;
  height: 84rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 700;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-modal-btn::after {
  border: none;
}

.login-modal-btn-cancel {
  background: #f3f4f6;
  color: #6b7280;
}

.login-modal-btn-confirm {
  background: linear-gradient(135deg, #9f0014, #d0021b);
  color: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(208, 2, 27, 0.22);
}
